{
  "info": {
    "name": "Bando API Test Flow",
    "description": "Full flow testing for Real Estate API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register" }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"token\", jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login" }
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/users/me" }
          }
        }
      ]
    },
    {
      "name": "Property",
      "item": [
        {
          "name": "Create Property",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Luxury Apartment\",\n  \"description\": \"Beautiful city view\",\n  \"price\": 1500000,\n  \"type\": \"Apartment\",\n  \"area\": 85.5,\n  \"address\": \"123 Main St, City\",\n  \"lat\": 10.762622,\n  \"lng\": 106.660172\n}"
            },
            "url": { "raw": "{{base_url}}/properties" }
          }
        },
        {
          "name": "Get Public List",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/properties" }
          }
        },
        {
          "name": "Nearby Search",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/properties/nearby?lat=10.762&lng=106.660&radius=5000"
            }
          }
        },
        {
          "name": "Get My Properties",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/properties/my" }
          }
        }
      ]
    },
    {
      "name": "Favorite",
      "item": [
        {
          "name": "Add Favorite",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/favorites/:propertyId" },
            "variable": [
              { "key": "propertyId", "value": "REPLACE_WITH_ID" }
            ]
          }
        },
        {
          "name": "List Favorites",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/favorites" }
          }
        },
        {
          "name": "Remove Favorite",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/favorites/:propertyId" },
            "variable": [
              { "key": "propertyId", "value": "REPLACE_WITH_ID" }
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ]
}
